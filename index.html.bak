                            <stop offset="0%" style="stop-color:#FF4500"/>
                            <stop offset="100%" style="stop-color:#FFB800"/>
                        </linearGradient>
                    </defs>
                    <circle cx="60" cy="60" r="56" fill="none" stroke="url(#logoGrad)" stroke-width="3" opacity="0.3"/>
