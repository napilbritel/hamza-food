                    <g transform="translate(38,34)" fill="url(#logoGrad)">
                        <path d="M22 0C10 0 0 7 0 15h44C44 7 34 0 22 0z"/>
                        <circle cx="12" cy="10" r="2" fill="#0d0d0d"/><circle cx="22" cy="7" r="2" fill="#0d0d0d"/><circle cx="32" cy="10" r="2" fill="#0d0d0d"/>
